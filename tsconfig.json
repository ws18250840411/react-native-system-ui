{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react",
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "react-native-system-ui": [
        "./components"
      ],
      "tailwind.config": [
        "./tailwind.config.js"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.md",
    "**/*.mdx",
    ".expo/types/**/*.ts",
    "global.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}