{
  "name": "react-native-system-ui",
  "version": "0.0.1",
  "description": "",
  "main": "dist/cjs/index.js",
  "module": "dist/es/index.js",
  "types": "dist/cjs/index.d.ts",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--require ./scripts/polyfills.js\" rndoc dev",
    "build": "NODE_OPTIONS=\"--require ./scripts/polyfills.js\" rndoc build",
    "docs:update-size": "node scripts/generate-docs-size-data.mjs",
    "docs:build": "npm run docs:update-size && NODE_OPTIONS=\"--require ./scripts/polyfills.js\" rndoc docs-build",
    "preview": "NODE_OPTIONS=\"--require ./scripts/polyfills.js\" rndoc preview",
    "rn:demos:sync": "node scripts/generate-rn-demo-registry.js",
    "rn:demos:watch": "node scripts/generate-rn-demo-registry.js --watch",
    "test": "NODE_OPTIONS=\"--require ./scripts/polyfills.js\" node node_modules/.pnpm/node_modules/jest/bin/jest.js --config node_modules/rndoc-cli/cjs/jest.config.cjs --rootDir . --runInBand",
    "test:watch": "NODE_OPTIONS=\"--require ./scripts/polyfills.js\" rndoc test --watch"
  },
  "files": [
    "dist/cjs",
    "dist/es",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/**.md",
    "!dist/*.mjs",
    "!dist/*.js"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "react-native": ">=0.79.0",
    "react-native-svg": ">=12.4.1"
  },
  "devDependencies": {
    "@jest/test-sequencer": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "jest-environment-jsdom": "30.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.83.0",
    "react-native-web": "0.21.2",
    "react-native-svg": "^15.15.1",
    "react-test-renderer": "^19.2.3",
    "rndoc-cli": "^2.0.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@react-native-aria/checkbox": "^0.2.10",
    "@react-native-aria/focus": "^0.2.9",
    "@react-native-aria/interactions": "^0.2.16",
    "@react-native-aria/listbox": "^0.2.9",
    "@react-native-aria/overlays": "^0.3.15",
    "@react-native-aria/radio": "^0.2.13",
    "@react-native-aria/slider": "^0.2.12",
    "@react-native-aria/toggle": "^0.2.11",
    "@react-native-aria/utils": "^0.2.12",
    "@react-stately/checkbox": "3.7.2",
    "@react-stately/list": "^3.13.2",
    "@react-stately/radio": "^3.11.3",
    "@react-stately/slider": "^3.7.3",
    "@react-stately/toggle": "^3.9.3",
    "@react-types/checkbox": "^3.10.2",
    "@react-types/listbox": "^3.7.4",
    "react-native-system-icon": "^1.0.2"
  }
}