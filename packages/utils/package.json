{
  "name": "react-native-system-utils",
  "version": "0.0.1",
  "description": "A focused utility toolkit shared across React Native System UI packages.",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Wang Wenshan <wangwenshan@gmail.com>",
  "license": "MIT",
  "keywords": [
    "react-native",
    "utilities",
    "design-system"
  ],
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}