{
  "name": "react-native-system-icons",
  "version": "0.0.1",
  "description": "SVG icon set for React Native System UI, inspired by react-vant-icons.",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Wang Wenshan <wangwenshan@gmail.com>",
  "license": "MIT",
  "keywords": [
    "react-native",
    "icons",
    "design-system"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.79.0",
    "react-native-svg": ">=13.0.0"
  },
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
