{
  "name": "react-native-system-ui",
  "version": "0.0.1",
  "description": "Responsive and accessible React Native UI components built with React Native and Emotion",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./src/foundation/portal/portal-host.tsx"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Wang Wenshan <wangwenshan@gmail.com>",
  "license": "MIT",
  "keywords": [
    "react-native",
    "ui",
    "design-system",
    "react-native-components",
    "accessible",
    "components"
  ],
  "dependencies": {
    "color": "^4.2.3",
    "fast-deep-equal": "^3.1.3",
    "lodash": "^4.17.21",
    "react-is": "^19.0.0",
    "react-native-popover-view": "^6.1.0",
    "react-native-system-utils": "*"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.81.4",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-svg": "^15.4.0",
    "rc-field-form": "^2.7.0",
    "@types/lodash": "^4.17.14",
    "@types/color": "^3.0.5"
  },
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./theme": {
      "dev": "./src/theme/index.ts",
      "import": {
        "types": "./dist/types/theme/index.d.ts",
        "default": "./dist/esm/theme/index.js"
      },
      "require": {
        "types": "./dist/types/theme/index.d.ts",
        "default": "./dist/cjs/theme/index.cjs"
      }
    },
    "./hooks": {
      "dev": "./src/hooks/index.ts",
      "import": {
        "types": "./dist/types/hooks/index.d.ts",
        "default": "./dist/esm/hooks/index.js"
      },
      "require": {
        "types": "./dist/types/hooks/index.d.ts",
        "default": "./dist/cjs/hooks/index.cjs"
      }
    },
    "./*": {
      "dev": "./src/components/*/index.ts",
      "import": {
        "types": "./dist/types/components/*/index.d.ts",
        "default": "./dist/esm/components/*/index.js"
      },
      "require": {
        "types": "./dist/types/components/*/index.d.ts",
        "default": "./dist/cjs/components/*/index.cjs"
      }
    },
    "./package.json": "./package.json",
    "./portal": {
      "dev": "./src/portal/index.ts",
      "import": {
        "types": "./dist/types/portal/index.d.ts",
        "default": "./dist/esm/portal/index.js"
      },
      "require": {
        "types": "./dist/types/portal/index.d.ts",
        "default": "./dist/cjs/portal/index.cjs"
      }
    },
    "./provider": {
      "dev": "./src/provider/index.ts",
      "import": {
        "types": "./dist/types/provider/index.d.ts",
        "default": "./dist/esm/provider/index.js"
      },
      "require": {
        "types": "./dist/types/provider/index.d.ts",
        "default": "./dist/cjs/provider/index.cjs"
      }
    },
    "./locale": {
      "dev": "./src/locale/index.ts",
      "import": {
        "types": "./dist/types/locale/index.d.ts",
        "default": "./dist/esm/locale/index.js"
      },
      "require": {
        "types": "./dist/types/locale/index.d.ts",
        "default": "./dist/cjs/locale/index.cjs"
      }
    },
    "./icons": {
      "dev": "./src/icons/index.ts",
      "import": {
        "types": "./dist/types/icons/index.d.ts",
        "default": "./dist/esm/icons/index.js"
      },
      "require": {
        "types": "./dist/types/icons/index.d.ts",
        "default": "./dist/cjs/icons/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.79.0",
    "react-native-safe-area-context": ">=4.6.0",
    "react-native-svg": ">=13.0.0",
    "rc-field-form": ">=1.32.0"
  }
}
